#!/bin/bash
# 0050-cleanup.hook.chroot — Clean up apt caches and temp files before squash
# Reduces the final ISO size significantly.

set -euo pipefail

echo "[hook:cleanup] Cleaning up build artifacts..."

# Remove apt cache
apt-get clean
rm -rf /var/lib/apt/lists/*

# Remove temporary files
rm -rf /tmp/* /var/tmp/*

# Remove man pages and docs (not needed in a headless agent OS)
rm -rf /usr/share/doc/* /usr/share/man/* /usr/share/info/*

# Remove locale files except en_US
find /usr/share/locale -mindepth 1 -maxdepth 1 \
  ! -name 'en' ! -name 'en_US' -exec rm -rf {} + 2>/dev/null || true

echo "[hook:cleanup] Done."
