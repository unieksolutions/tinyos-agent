# TinyOS Agent — .gitignore

# live-build working directories
build/cache/
build/chroot/
build/binary/
build/.build/
build/live-image-*.iso
build/live-image-*.img
build/live-image-*.tar
build/build.log

# Generated ISO (tracked separately via sha256 sidecar)
*.iso
*.img

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
.env

# Editor
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store
build/.lock
build/chroot*
build/wget-log*
build/*.iso
build/*.sha256
build/build.log
